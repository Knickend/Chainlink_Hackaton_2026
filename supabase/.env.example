# Supabase Edge Function environment variables (example)
# Do NOT commit real keys. Use your Supabase project settings to set these securely.

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Configure Chainlink feeds for the fetch-chainlink-feeds Edge Function.
# CHAINLINK_FEEDS must be a JSON array (stringified) of objects with: pair, network, rpc, address
# Example value (single-line JSON string; keep inside single quotes if placing in a shell env file):
# CHAINLINK_FEEDS='[{"pair":"EUR/USD","network":"sepolia","rpc":"https://rpc.sepolia.example","address":"0x0000000000000000000000000000000000000000"}]'

# Safe example (uses placeholder RPC and zero addresses):
CHAINLINK_FEEDS='[{"pair":"EUR/USD","network":"sepolia","rpc":"https://rpc.sepolia.example","address":"0x0000000000000000000000000000000000000000"},{"pair":"BTC/USD","network":"sepolia","rpc":"https://rpc.sepolia.example","address":"0x0000000000000000000000000000000000000000"}]'
